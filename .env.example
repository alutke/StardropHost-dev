# ===========================================
# StardropHost | .env
# ===========================================
# Just run:
#   docker compose up -d
#
# Then open:
#   http://CONTAINER_IP:18642
#
# The setup wizard will handle everything!
# ===========================================


# -- Network --
# Each instance needs its own unique IP on your LAN.
# Pick one that's outside your router's DHCP range.
#
# Find your interface:   ip route | grep default | awk '{print $5}'
# Find your subnet:      ip route | grep -v default | awk '{print $1}' | head -1
# Find your gateway:     ip route | grep default | awk '{print $3}'
#
CONTAINER_IP=192.168.1.150
HOST_INTERFACE=eth0
LAN_SUBNET=192.168.1.0/24
LAN_GATEWAY=192.168.1.1


# -- Instance --
# Change CONTAINER_PREFIX when running multiple instances
# so container names don't clash (e.g. stardrop-1, stardrop-2)
CONTAINER_PREFIX=stardrop


# -- Panel --
# Port the web panel listens on inside the container.
# Accessible at http://CONTAINER_IP:PANEL_PORT
# No need to change this for multiple instances (each has its own IP).
PANEL_PORT=18642


# -- Game Files --
# Set automatically by the setup wizard
GAME_PATH=
STEAM_DOWNLOAD=false


# -- Resources --
# Set automatically by the setup wizard
CPU_LIMIT=2.0
MEMORY_LIMIT=2G


# -- VNC --
# Off by default, toggle via web UI
ENABLE_VNC=false
VNC_PASSWORD=


# -- Rendering --
DISABLE_RENDERING=true
USE_GPU=false


# -- Display --
RESOLUTION_WIDTH=1280
RESOLUTION_HEIGHT=720
REFRESH_RATE=60


# -- Performance --
LOW_PERF_MODE=false
TARGET_FPS=


# -- Timezone --
TZ=UTC


# -- Logging --
ENABLE_LOG_MONITOR=true


# -- Backups --
# 1 backup per day at 4am, kept for 7 days
ENABLE_AUTO_BACKUP=true
MAX_BACKUPS=7
BACKUP_HOUR=4
BACKUP_COMPRESSION_LEVEL=1


# -- Crash Recovery --
ENABLE_CRASH_RESTART=false
MAX_CRASH_RESTARTS=5


# -- Save --
SAVE_NAME=


# -- Server --
PUBLIC_IP=
SERVER_PASSWORD=
SERVER_MODE=lan


# ===========================================
# Multi-instance setup
# ===========================================
#
# To run a second instance on the same host:
#   cp -r stardrophost stardrophost-2
#   cd stardrophost-2
#   Edit .env:
#     CONTAINER_IP=192.168.1.151   ← unique LAN IP
#     CONTAINER_PREFIX=stardrop-2  ← unique container names
#   docker compose up -d
#
# Each instance appears as a separate device on your LAN.
# Clients connect to different IPs — no port conflicts.
#
# ===========================================
# Troubleshooting
# ===========================================
#
# Can't reach the web panel?
#   Ensure CONTAINER_IP is free and not in your DHCP range
#   Check your interface name:  ip route | grep default
#
# Players can't connect?
#   Game port 24642/udp is directly on CONTAINER_IP — no firewall
#   rules needed on the host, but your network switch/router must
#   allow the macvlan IP (most do by default)
#
# For help:
#   https://github.com/Tomomoto10/StardropHost
# ===========================================
