# ===========================================
# StardropHost | .env
# ===========================================
# Environment variables for Dockhand deployment.
#
# Dockhand supplies this file to the remote Docker host.
# The Docker host does NOT clone this repository.
#
# Copy this file, fill in the values, and configure Dockhand
# to deploy compose.dockhand.yml with these variables.
# ===========================================


# -- Instance --
# Change when running multiple instances on the same host
# so container names don't clash (e.g. stardrop-1, stardrop-2)
CONTAINER_PREFIX=stardrop


# -- Network --
# Static IP for the game server inside the Docker network.
# Must be within NETWORK_SUBNET.
SERVER_IP=172.30.0.10
NETWORK_SUBNET=172.30.0.0/24


# -- Ports --
# Change these if running multiple instances on the same host.
# Each instance needs unique port numbers.
PANEL_PORT=18642
GAME_PORT=24642
VNC_PORT=5900
METRICS_PORT=9090


# -- Security --
# Shared secret between the web panel and the manager sidecar.
# Generate a strong random string. Do NOT use the default in production.
MANAGER_SECRET=changeme


# -- Deployment Mode --
# Set to 'external-compose' when deploying via an external Compose tool
# (e.g. Dockhand, Portainer, Dockge, Compose over SSH, Docker contexts).
# This hides unsupported UI actions (self-update, multi-instance wizard,
# remote compose) and adjusts the web panel for registry-image deployments.
DEPLOYMENT_MODE=external-compose


# -- Game Files --
# Set automatically by the setup wizard; leave empty for initial deploy.
GAME_PATH=
STEAM_DOWNLOAD=false


# -- Resources --
CPU_LIMIT=2.0
MEMORY_LIMIT=2G


# -- VNC --
# Off by default, toggle via web UI
ENABLE_VNC=false
VNC_PASSWORD=


# -- Rendering --
DISABLE_RENDERING=true
USE_GPU=false


# -- Display --
RESOLUTION_WIDTH=1280
RESOLUTION_HEIGHT=720
REFRESH_RATE=60


# -- Display (override Xvfb resolution/fps — default 800x600@30) --
TARGET_FPS=


# -- Timezone --
TZ=Europe/London


# -- Logging --
ENABLE_LOG_MONITOR=true

# -- Update checks --
# How often to check GitHub for StardropHost updates (hours). Set to 0 to disable.
PANEL_UPDATE_CHECK_HOURS=24


# -- Backups --
# 1 backup per day at 4am, kept for 7 days
ENABLE_AUTO_BACKUP=true
MAX_BACKUPS=7
BACKUP_HOUR=4
BACKUP_COMPRESSION_LEVEL=1


# -- Crash Recovery --
ENABLE_CRASH_RESTART=false
MAX_CRASH_RESTARTS=5

# -- Game Sleep --
# Stops the game process when no farmhands are connected.
# The web panel stays online and can wake the game manually.
ENABLE_GAME_SLEEP=false
SLEEP_IDLE_MINUTES=10
ENABLE_AUTO_WAKE=true


# -- Save --
SAVE_NAME=


# -- Server --
PUBLIC_IP=
SERVER_PASSWORD=
SERVER_MODE=lan


# -- playit.gg (optional online tunnel) --
# Managed via the Remote tab in the web panel — no config needed here.
# The tunnel is started/stopped from the UI; the key is held in memory only.


# ===========================================
# Running multiple instances on the same host
# ===========================================
#
# For LAN play: each instance needs its own IP — use a separate
# VM per instance. Each VM gets its own IP and port 24642 naturally.
#
# For online play: multiple instances on the same host work fine —
# set unique ports and each instance gets a unique SERVER_IP inside
# its own subnet. Use Dockhand to deploy separate stacks.
#
# Example second instance:
#   CONTAINER_PREFIX=stardrop-2
#   SERVER_IP=172.31.0.10
#   NETWORK_SUBNET=172.31.0.0/24
#   PANEL_PORT=18643
#   GAME_PORT=24643
