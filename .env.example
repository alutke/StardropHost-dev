# ===========================================
# StardropHost | .env
# ===========================================
# Just run:
#   docker compose up -d
#
# Then open:
#   http://your-server-ip:18642
#
# The setup wizard will handle everything!
# ===========================================


# -- Instance --
# Change when running multiple instances on the same host
# so container names don't clash (e.g. stardrop-1, stardrop-2)
CONTAINER_PREFIX=stardrop


# -- Ports --
# Change these if running multiple instances on the same host.
# Each instance needs unique port numbers.
PANEL_PORT=18642
GAME_PORT=24642
VNC_PORT=5900
METRICS_PORT=9090


# -- HTTPS --

# -- Game Files --
# Set automatically by the setup wizard
GAME_PATH=
STEAM_DOWNLOAD=false


# -- Resources --
# Set automatically by the setup wizard
CPU_LIMIT=2.0
MEMORY_LIMIT=2G


# -- VNC --
# Off by default, toggle via web UI
ENABLE_VNC=false
VNC_PASSWORD=


# -- Rendering --
DISABLE_RENDERING=true
USE_GPU=false


# -- Display --
RESOLUTION_WIDTH=1280
RESOLUTION_HEIGHT=720
REFRESH_RATE=60


# -- Display (override Xvfb resolution/fps — default 800x600@30) --
TARGET_FPS=


# -- Timezone --
TZ=UTC


# -- Logging --
ENABLE_LOG_MONITOR=true

# -- Update checks --
# How often to check GitHub for StardropHost updates (hours). Set to 0 to disable.
PANEL_UPDATE_CHECK_HOURS=24


# -- Backups --
# 1 backup per day at 4am, kept for 7 days
ENABLE_AUTO_BACKUP=true
MAX_BACKUPS=7
BACKUP_HOUR=4
BACKUP_COMPRESSION_LEVEL=1


# -- Crash Recovery --
ENABLE_CRASH_RESTART=false
MAX_CRASH_RESTARTS=5


# -- Save --
SAVE_NAME=


# -- Server --
PUBLIC_IP=
SERVER_PASSWORD=
SERVER_MODE=lan


# -- playit.gg (optional online tunnel) --
# Managed via the Remote tab in the web panel — no config needed here.
# The tunnel is started/stopped from the UI; the key is held in memory only.


# ===========================================
# Running multiple instances on the same host
# ===========================================
#
# For LAN play: each instance needs its own IP — use a separate
# VM per instance. Each VM gets its own IP and port 24642 naturally.
#
# For online play: multiple instances on the same host work fine —
# set unique ports and each instance gets its own invite code.
#
#   Instance 2 example:
#     CONTAINER_PREFIX=stardrop-2
#     PANEL_PORT=18643
#     GAME_PORT=24643
#     VNC_PORT=5901
#     METRICS_PORT=9091
#
# ===========================================
# Troubleshooting
# ===========================================
#
# Players can't connect:
#   Ensure port 24642/udp is open in your firewall
#   Ubuntu/Debian:  sudo ufw allow 24642/udp
#   CentOS/RHEL:    sudo firewall-cmd --add-port=24642/udp --permanent
#
# For help:
#   https://github.com/Tomomoto10/StardropHost
# ===========================================
